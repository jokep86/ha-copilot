# Local development overrides (NOT used inside the HA add-on).
# In add-on, all config comes from /data/options.json (Supervisor-managed).
# Copy this file to .env and fill in values for local dev/testing.

# Path overrides (used by app code via os.environ)
HA_OPTIONS_PATH=./tests/fixtures/options.json
HA_DB_PATH=./data/ha_copilot.db
HA_LOGS_DIR=./data/logs
HA_MIGRATIONS_DIR=./migrations

# Supervisor token (injected automatically in add-on; set manually for local dev)
SUPERVISOR_TOKEN=your_long_lived_access_token_here
